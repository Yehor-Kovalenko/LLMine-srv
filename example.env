# Server
SERVER_DEV_RELOAD=false
SERVER_HOST=127.0.0.1
SERVER_PORT=8000


# Security
API_KEY=

# Models registry
MODEL_REGISTRY_BACKEND=local
LOCAL_REGISTRY_DIR=%USERPROFILE%\\.local_models
OLLAMA_MODELS=
HF_HOME=

# Model caching
MODEL_TTL_SECONDS=3600

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_BYTES=10485760   # 10 MB per file
LOG_BACKUP_COUNT=5